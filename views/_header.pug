header.header
    nav.nav.nav--tours
        a.nav_el(href='/' class='nav__el') All tours
        form.nav__search
            button.nav__search-btn
                svg
                    use(xlink:href='/img/icons.svg#icon-search')
            input(type='text' placeholder='Search tours' class='nav__search-input')
    div.header__logo
        img(src='/img/logo-white.png' alt='Natours logo')
    nav.nav.nav--user
        if user
            a.nav__el.nav__el--logout Log out
            a.nav__el(href='/me') 
                img(src=`/img/users/${user.photo}` alt='User photo' class='nav__user-img')
                span= user.name.split(' ')[0]
        else
            a.nav__el(href='/login') Log in
            button.nav__el.nav__el--cta Sign up